# =============================================================================
# GLOBAL ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your API keys
# =============================================================================

# ==== API Keys ====
FINNHUB_API_KEY=your_finnhub_api_key_here
FINVIZ_API_KEY=your_finviz_api_key_here
FRED_API_KEY=your_fred_api_key_here

# ==== Finnhub Producer Settings ====
# Comma-separated list of symbols to track
FINNHUB_SYMBOLS=BINANCE:BTCUSDT,AAPL,TSLA,MSFT,NVDA

# ==== News Producer Settings ====
# Comma-separated list of tickers to fetch news for
NEWS_TICKERS=NVDA,AAPL,TSLA,MSFT,GOOG,AMZN
# Poll interval in seconds
NEWS_POLL_INTERVAL=60

# ==== Sentiment Producer Settings ====
# Comma-separated list of tickers for sentiment analysis
SENTIMENT_TICKERS=TSLA,AAPL,MSFT,NVDA,GOOG,AMZN,JPM
# EWMA smoothing factor (higher = more responsive to new data)
SENTIMENT_ALPHA=0.05
SENTIMENT_POLL_INTERVAL=60

# ==== Macro (FRED) Producer Settings ====
# Fetch interval in seconds (3600 = 1 hour)
FRED_FETCH_INTERVAL=3600
FRED_START_DATE=1990-01-01

# ==== Spike Detector Settings ====
# Rolling window duration for statistics
ROLLING_WINDOW_DURATION=5m
# How often to calculate (hop)
ROLLING_WINDOW_HOP=10s
# Minimum bars needed for stable statistics
MIN_BARS_FOR_STATS=5
# Z-score threshold for spike detection
SPIKE_THRESHOLD=3.0
