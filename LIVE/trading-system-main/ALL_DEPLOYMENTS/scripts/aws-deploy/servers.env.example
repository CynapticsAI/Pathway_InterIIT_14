# =============================================================================
# AWS MULTI-SERVER DEPLOYMENT CONFIGURATION
# =============================================================================
# Copy this file to servers.env and fill in your values
# Usage: ./deploy-all.sh servers.env
# =============================================================================

# SSH Configuration
SSH_KEY=~/.ssh/your-key.pem
SSH_USER=ubuntu

# Server IPs (use private IPs if in same VPC, public IPs if deploying remotely)
# For single-server deployment, set all IPs to the same value
KAFKA_SERVER=10.0.1.10
MACRO_SERVER=10.0.1.11
CHRONOS_SERVER=10.0.1.12
PORTFOLIO_SERVER=10.0.1.13

# =============================================================================
# API KEYS (these will be copied to each server)
# =============================================================================
FINNHUB_API_KEY=your_finnhub_api_key
FRED_API_KEY=your_fred_api_key
FINVIZ_API_KEY=your_finviz_api_key

# =============================================================================
# PRODUCER CONFIGURATION
# =============================================================================
FINNHUB_SYMBOLS=BINANCE:BTCUSDT,AAPL,TSLA,MSFT,NVDA
NEWS_TICKERS=NVDA,AAPL,TSLA,MSFT
SENTIMENT_TICKERS=TSLA,AAPL,MSFT,NVDA
