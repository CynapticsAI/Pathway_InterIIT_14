# Dockerfile.consumer
FROM python:3.11-slim

WORKDIR /app

# Install netcat for healthcheck
RUN apt-get update && apt-get install -y netcat-openbsd && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY pathway_consumer_training.py .

# Wait for Kafka and producer before starting
CMD ["sh", "-c", "echo 'Waiting for Kafka and producer...' && sleep 45 && python pathway_consumer_training.py"]