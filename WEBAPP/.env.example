# ======================
# Frontend Environment Variables
# ======================
NEXT_PUBLIC_API_URL=http://13xxxx135:8000
NEXT_PUBLIC_WS_URL=ws://13xxxx135:8000

# ======================
# Backend Environment Variables
# ======================
DEBUG=True
SECRET_KEY=django-insecure-change-this-in-production
ALLOWED_HOSTS=*

# Frontend URL (used for email templates and redirects)
FRONTEND_URL=http://13xxxx135:3000

# ======================
# Email Configuration
# ======================
# For development: console backend (prints to terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# For production: SMTP backend (actually sends emails)
# Uncomment and configure one of the options below:

# Option 1: Gmail SMTP
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-16-char-app-password
# DEFAULT_FROM_EMAIL=your-email@gmail.com

# Option 2: SendGrid
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-sendgrid-api-key
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Option 3: AWS SES
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=email-smtp.us-east-1.amazonaws.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-ses-smtp-username
# EMAIL_HOST_PASSWORD=your-ses-smtp-password
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Database (if using PostgreSQL instead of SQLite)
# DATABASE_URL=postgresql://user:password@db:5432/pway_stock

# ======================
# Kafka Configuration
# ======================
# For Docker containers (internal network)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# For external access (set to your server's public IP or domain)
# Used by docker-compose.yml for KAFKA_ADVERTISED_LISTENERS
KAFKA_EXTERNAL_HOST=13xxxx135

# ======================
# Redis (if needed)
# ======================
# REDIS_URL=redis://redis:6379/0

# ======================
# CORS Settings
# ======================
CORS_ALLOWED_ORIGINS=http://13xxxx135:3000,http://frontend:3000
